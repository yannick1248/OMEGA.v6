{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OmegaAI Training Example",
  "type": "object",
  "required": ["messages", "meta"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["task", "domain", "difficulty", "expected_proofs"],
      "properties": {
        "task": { "type": "string" },
        "domain": { "type": "string", "enum": ["syntax", "medical", "compression", "safety"] },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "expected_proofs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
